# ============================================================
# PINTEREST AI AGENT — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ============================================================

# === REQUIRED: Anthropic Claude API ===
# Get from: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-xxxx

# === REQUIRED: Pinterest API ===
# Get from: https://developers.pinterest.com/apps/
# Create a Pinterest Business account, create an app, generate OAuth token
PINTEREST_ACCESS_TOKEN=your_pinterest_oauth_access_token_here

# Optional: Pinterest Ad Account ID (for analytics access)
PINTEREST_AD_ACCOUNT_ID=

# === BUSINESS SETTINGS ===
BUSINESS_NAME=Your Drop Shipping Store
WEBSITE_URL=https://yourstore.com
PRIMARY_NICHE=home organization, kitchen gadgets, lifestyle products, gift ideas
BRAND_VOICE=helpful, aspirational, value-focused, specific

# === PUBLISHING SETTINGS ===
DAILY_PIN_LIMIT=25
WEEKLY_PIN_TARGET=15
FRESH_PIN_RATIO=0.8

# === DATABASE ===
DB_PATH=pinterest_agent.db

# ============================================================
# HOW TO GET YOUR PINTEREST ACCESS TOKEN:
# 1. Go to https://developers.pinterest.com
# 2. Create a developer app
# 3. Set redirect URI to https://localhost
# 4. Use OAuth 2.0 to get an access token with these scopes:
#    - boards:read
#    - boards:write
#    - pins:read
#    - pins:write
#    - user_accounts:read
#    - analytics:read (for analytics features)
# 5. Paste the token above
# ============================================================
