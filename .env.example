# ============================================================
# SHIPSTACK AI + QUINN — MASTER .env.example
# Copy this to .env and fill in real values.
# NEVER commit .env to GitHub.
# ============================================================

# -- Quinn Local Bridge (primary LLM router) ------------------
# Start with: START_QUINN_BRIDGE.bat
# Expose with: ngrok http <QUINN_BRIDGE_PORT>
QUINN_BRIDGE_PORT=8765
QUINN_BRIDGE_SECRET=your-bridge-secret-here
QUINN_ENDPOINT=https://your-ngrok-url.ngrok.io
QUINN_TIMEOUT_MS=30000
QUINN_LOCAL_MODEL=qwen2.5:7b
QUINN_COMPRESS_MODEL=qwen2.5:3b

# -- Embedded chat box (LOCAL QUINN ONLY — no fallback) --------
# Points directly at the local bridge (no ngrok needed if same machine).
# Embedded chat FAILS CLOSED if this is unavailable.
QUINN_LOCAL_API_URL=http://localhost:8765
QUINN_LOCAL_TIMEOUT_MS=30000

# -- ShipStack Engine (secondary ops profile) -----------------
SHIPSTACK_ENGINE_PORT=8889
SHIPSTACK_MODEL=qwen2.5:7b

# -- Prometheus Engine ----------------------------------------
PROMETHEUS_ENGINE_PORT=8766

# -- Fallback LLM (Anthropic — only if Quinn fails) -----------
FALLBACK_ENABLED=true
FALLBACK_PROVIDER=anthropic
FALLBACK_API_URL=https://api.anthropic.com/v1/messages
FALLBACK_MODEL=claude-sonnet-4-5
FALLBACK_TIMEOUT_MS=60000
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -- App profile routing --------------------------------------
APP_PRIMARY_PROFILE=quinn
APP_SECONDARY_PROFILE=shipstack

# -- Tool call log path ---------------------------------------
TOOL_LOG_PATH=./logs/tool-calls.jsonl

# -- Local AI stack -------------------------------------------
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:7b
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=general_knowledge
QDRANT_EMBEDDING_MODEL=all-MiniLM-L6-v2

# -- Vercel site ----------------------------------------------
VERCEL_SITE_URL=https://your-site.vercel.app
VERCEL_TOKEN=your-vercel-token
VERCEL_PROJECT_ID=your-project-id
VERCEL_TEAM_ID=your-team-id

# -- Stripe ---------------------------------------------------
STRIPE_SECRET_KEY=sk_live_your-key-here
STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
STRIPE_SUCCESS_URL=https://your-site.vercel.app/thank-you
STRIPE_CANCEL_URL=https://your-site.vercel.app

# -- Pinterest ------------------------------------------------
PINTEREST_ACCESS_TOKEN=your-token-here
PINTEREST_APP_ID=your-app-id
PINTEREST_APP_SECRET=your-app-secret
PINTEREST_DEFAULT_BOARD_ID=your-board-id
PINTEREST_BOARD_ID=your-board-id

# -- Meta (Instagram / Facebook) ------------------------------
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_IG_ACCOUNT_ID=
META_PAGE_ID=

# -- TikTok ---------------------------------------------------
TIKTOK_CLIENT_KEY=your-client-key
TIKTOK_CLIENT_SECRET=your-client-secret
TIKTOK_ACCESS_TOKEN=

# -- YouTube --------------------------------------------------
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token

# -- Suppliers ------------------------------------------------
ZENDROP_API_KEY=your-key-here
AUTODS_API_KEY=
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=

# -- GitHub Pages ---------------------------------------------
GITHUB_TOKEN=your-github-token
GITHUB_USERNAME=your-username
GITHUB_PAGES_REPO=your-repo

# -- AI Content Tools -----------------------------------------
RUNWAY_API_KEY=your-key-here
ELEVENLABS_API_KEY=your-key-here
HEYGEN_API_KEY=your-key-here

# -- OpenAI (optional secondary) ------------------------------
OPENAI_API_KEY=

# -- AI model selection (social_ai_agent) ---------------------
MODEL_OPENAI=gpt-4o
MODEL_ANTHROPIC=claude-sonnet-4-5

# -- Business profile -----------------------------------------
BUSINESS_NICHE=dropshipping
BUSINESS_NAME=ShipStack AI
WEBSITE_URL=https://your-site.vercel.app
LANDING_PAGE_URL=https://your-site.vercel.app
TARGET_PRODUCTS=pet accessories,home kitchen,fitness tools,posture corrector
DEFAULT_PRODUCT_IMAGE_URL=

# -- Ngrok ----------------------------------------------------
NGROK_AUTHTOKEN=your-authtoken-here

# -- Tools ----------------------------------------------------
FFMPEG_PATH=C:\path\to\ffmpeg\bin
