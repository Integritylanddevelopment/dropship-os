# ============================================
# DROPSHIP INTELLIGENCE AGENT - ENVIRONMENT
# ============================================
# Copy this file to .env and fill in your keys

# REQUIRED: Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OPTIONAL: Serp API for better search results (serpapi.com - free tier available)
SERP_API_KEY=

# OPTIONAL: ScraperAPI for marketplace data (scraperapi.com - free tier available)
SCRAPER_API_KEY=

# AGENT SETTINGS
AGENT_MODEL=claude-sonnet-4-6
MAX_PRODUCTS=10
MAX_CHANNELS=10
RESEARCH_DEPTH=deep
CACHE_TTL_HOURS=6

# DASHBOARD SERVER
DASHBOARD_PORT=3000
AUTO_OPEN_DASHBOARD=true

# REPORTING
REPORT_OUTPUT_DIR=./reports
SAVE_RAW_DATA=true
