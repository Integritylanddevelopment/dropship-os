{
  "version": "1.0",
  "weights": {
    "demand": 0.25,
    "competition": 0.20,
    "attentionCost": 0.20,
    "margin": 0.20,
    "launchSpeed": 0.15
  },
  "demandSignals": {
    "searchVolume":        { "weight": 0.25, "description": "Monthly search volume for product keywords" },
    "socialEngagement":    { "weight": 0.25, "description": "TikTok/Instagram engagement rate on related content" },
    "trendVelocity":       { "weight": 0.20, "description": "Rate of growth in mentions/searches" },
    "repeatPurchase":      { "weight": 0.15, "description": "Likelihood of reorder or subscription" },
    "impulsePotential":    { "weight": 0.10, "description": "Likelihood of unplanned purchase" },
    "problemStrength":     { "weight": 0.05, "description": "How painful the problem solved is (1-10)" }
  },
  "competitionSignals": {
    "sellerCount":         { "weight": 0.30, "description": "Number of active dropship sellers" },
    "adDensity":           { "weight": 0.25, "description": "How many ads running on search/social" },
    "brandDominance":      { "weight": 0.20, "description": "Whether major brands own this space" },
    "listingQuality":      { "weight": 0.15, "description": "Quality of competitor listings (weak = opportunity)" },
    "reviewVolume":        { "weight": 0.10, "description": "How many reviews top sellers have" }
  },
  "marginSignals": {
    "grossMarginPct":      { "weight": 0.40, "description": "Gross margin percentage after COGS + shipping" },
    "aov":                 { "weight": 0.25, "description": "Average order value" },
    "cacTolerance":        { "weight": 0.20, "description": "How much CAC the margin can absorb" },
    "returnRisk":          { "weight": 0.15, "description": "Likelihood of returns/chargebacks (lower = better)" }
  },
  "launchSpeedSignals": {
    "sourcingEase":        { "weight": 0.30, "description": "How quickly supplier can be found" },
    "listingComplexity":   { "weight": 0.25, "description": "How complex the product listing is" },
    "contentCreationTime": { "weight": 0.25, "description": "How fast winning content can be made" },
    "regulatoryRisk":      { "weight": 0.20, "description": "Legal/regulatory barriers (lower = faster)" }
  },
  "scoreLabels": {
    "9.0-10.0": "EXCEPTIONAL — Launch immediately",
    "8.0-8.9":  "STRONG — High priority",
    "7.0-7.9":  "GOOD — Worth testing",
    "6.0-6.9":  "MODERATE — Test with low budget",
    "5.0-5.9":  "WEAK — Skip or monitor",
    "0-4.9":    "AVOID"
  }
}
